{
	"name": "@sudoo/token",
	"packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
	"version": "1.7.0",
	"description": "Token generator and signature validator",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc --p typescript/tsconfig.build.json",
		"prepublishOnly": "pnpm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SudoDotDog/Sudoo-Token.git"
	},
	"keywords": [
		"Token"
	],
	"author": "WMXPY",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/SudoDotDog/Sudoo-Token/issues"
	},
	"homepage": "https://github.com/SudoDotDog/Sudoo-Token#readme",
	"devDependencies": {
		"@sudoo/build-utils": "^1.0.0",
		"@sudoo/triforce": "^3.12.0"
	},
	"nyc": {
		"extension": [
			".ts"
		],
		"include": [
			"script/**/*.ts",
			"src/**/*.ts"
		],
		"instrument": true,
		"reporter": [
			"json",
			"text-summary"
		],
		"report-dir": "coverage",
		"sourceMap": true
	}
}
